network:
  version: 2
  renderer: networkd
  ethernets:
    ens21f0np0:
      dhcp4: false
      dhcp6: false
    ens21f1np1:
      dhcp4: false
      dhcp6: false
  bridges:
    br0:
      interfaces: [ens21f0np0]
      addresses: [192.168.1.71/24]
      routes:
        - to: default
          via: 192.168.1.5
      nameservers:
        addresses: [8.8.8.8, 1.1.1.1]
      parameters:
        stp: false
        forward-delay: 0
      dhcp4: false
